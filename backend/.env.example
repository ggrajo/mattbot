# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# DATABASE_URL: PostgreSQL connection string with async driver (asyncpg)
# - Used for: async database operations in the backend API
# - Change when: connecting to a different PostgreSQL instance (local, prod, staging)
# - Format: postgresql+asyncpg://user:password@host:port/database
# - Dev example: postgresql+asyncpg://mattbot:mattbot@localhost:5432/mattbot
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mattbot?sslmode=require

# DATABASE_URL_SYNC: PostgreSQL connection string with sync driver (psycopg)
# - Used for: Alembic migrations and synchronous database operations
# - Change when: connecting to a different PostgreSQL instance
# - Must point to the SAME database as DATABASE_URL
# - Format: postgresql://user:password@host:port/database
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/mattbot?sslmode=require

# =============================================================================
# REDIS CONFIGURATION (Sessions, Rate Limiting, Token Stores)
# =============================================================================
# REDIS_URL: Redis connection string for session/cache storage
# - Used for: session management, rate limit tracking, token blacklisting
# - Change when: running Redis on a different host/port or in production
# - Format: redis://[user[:password]@]host:port[/db_number]
# - Dev example: redis://localhost:6379
REDIS_URL=redis://default:password@localhost:6379

# =============================================================================
# JWT (JSON Web Token) CONFIGURATION
# =============================================================================
# JWT_SIGNING_KEY: Secret key for signing JWT tokens (minimum 32 bytes)
# - Used for: signing access/refresh tokens for authentication
# - Change when: implementing in production (MUST use a strong random key)
# - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# - NEVER commit the actual key - use a secret management system in prod
JWT_SIGNING_KEY=CHANGE_ME_generate_a_32_byte_random_key

# JWT_KEY_ID: Key identifier for JWT algorithm (used in key rotation)
# - Used for: identifying which key version was used to sign a token
# - Change when: rotating keys in production
# - Format: alphanumeric string (e.g. "key-001", "key-prod-2024")
JWT_KEY_ID=key-001

# =============================================================================
# ENCRYPTION CONFIGURATION (TOTP Secrets and Sensitive Data)
# =============================================================================
# ENCRYPTION_MASTER_KEY: Master key for encrypting sensitive fields (64-char hex)
# - Used for: encrypting TOTP secrets, personal phone numbers, payment details at rest
# - Change when: implementing in production (MUST use a strong random key)
# - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# - NEVER commit the actual key - use AWS KMS or similar in prod
# - CRITICAL: Losing this key makes all encrypted data unrecoverable
ENCRYPTION_MASTER_KEY=CHANGE_ME_generate_a_32_byte_hex_key_64chars

# =============================================================================
# OAUTH PROVIDERS (Google, Apple Sign-In)
# =============================================================================
# GOOGLE_CLIENT_ID: OAuth client ID for Google Sign-In (web client)
# - Used for: authenticating users via Google OAuth on web
# - Obtain from: Google Cloud Console > APIs & Services > Credentials
# - Format: numeric-string.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# GOOGLE_ANDROID_CLIENT_ID: OAuth client ID for Google Sign-In (Android)
# - Used for: validating Google ID tokens from Android devices
# - The Android Google Sign-In SDK issues tokens with this audience
# - Obtain from: Google Cloud Console > APIs & Services > Credentials (Android type)
# - Set to the same value as GOOGLE_WEB_CLIENT_ID used in mobile/.env
GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com

# APPLE_BUNDLE_ID: iOS app bundle identifier (format: com.company.app)
# - Used for: verifying Apple Sign-In tokens
# - Change when: using a different iOS app or deploying to production
# - Obtain from: Xcode > Build Settings > Product Bundle Identifier
# - Must match: bundle identifier in Xcode project settings
APPLE_BUNDLE_ID=com.mattbot.app

# APPLE_TEAM_ID: Apple Developer Team ID for Sign-In verification
# - Used for: validating Apple identity tokens
# - Change when: using a different Apple Developer Team
# - Obtain from: Apple Developer Account > Membership > Team ID
# - Format: 10-character alphanumeric string
APPLE_TEAM_ID=your-apple-team-id

# =============================================================================
# EMAIL CONFIGURATION (OTP, Verification, Security Alerts)
# =============================================================================
# EMAIL_PROVIDER: Email service provider
# - Options: "console" (dev, logs to terminal), "smtp" (Gmail), "sendgrid" (API)
# - Change when: switching email providers or deploying to production
# - Dev: use "console" to see emails in terminal output
# - Prod: use "sendgrid" (most reliable) or "smtp"
EMAIL_PROVIDER=console

# EMAIL_FROM: Sender email address for all outbound emails
# - Used for: From header in OTP, verification, and security emails
# - Change when: changing email domain or deploying to production
# - Must be: a valid email address from your domain
EMAIL_FROM=noreply@mattbot.app

# SMTP_HOST, SMTP_PORT, SMTP_USERNAME, SMTP_PASSWORD: Gmail SMTP credentials
# - Used for: sending emails via Gmail SMTP (only if EMAIL_PROVIDER=smtp)
# - Change when: using a different SMTP provider
# - Gmail setup:
#   1. Enable 2FA in Gmail account
#   2. Generate App Password: https://myaccount.google.com/apppasswords
#   3. Use the 16-character password as SMTP_PASSWORD
# - NEVER use your Gmail password directly - use App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your.gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# SENDGRID_API_KEY: SendGrid API key for email delivery (only if EMAIL_PROVIDER=sendgrid)
# - Used for: sending transactional emails via SendGrid (production recommended)
# - Change when: switching to SendGrid or updating API key
# - Obtain from: SendGrid > Settings > API Keys
# - Format: SG.xxxxxxx... (starts with "SG.")
# - NEVER commit the actual key - use GitHub Secrets or AWS Secrets Manager
# SENDGRID_API_KEY=SG.xxxx

# =============================================================================
# DEEP LINKING CONFIGURATION (Email Links for Auth)
# =============================================================================
# APP_LINK_BASE_URL: Base URL for email verification and password reset links
# - Used for: generating clickable links in verification/password reset emails
# - Change when: deploying to production
# - Dev options:
#   - Leave empty: uses mattbot:// deep link scheme (console dev only)
#   - http://10.0.2.2:8000: Android emulator (if backend runs on host)
#   - http://localhost:8000: local testing
# - Prod examples: https://api.mattbot.app, https://mattbot.example.com
APP_LINK_BASE_URL=

# =============================================================================
# PUSH NOTIFICATIONS (FCM for Android, APNS for iOS)
# =============================================================================
# FCM_SERVICE_ACCOUNT_JSON: Path to Firebase service account JSON file
# - Used for: sending push notifications to Android devices
# - Change when: setting up Firebase or deploying
# - Obtain from: Firebase Console > Project Settings > Service Accounts > Generate JSON
# - File contains: private_key, private_key_id, client_email
# - Dev note: Leave commented to disable push notifications
# FCM_SERVICE_ACCOUNT_JSON=/path/to/firebase-service-account.json

# APNS_KEY_ID, APNS_TEAM_ID, APNS_AUTH_KEY: Apple Push Notification Service credentials
# - Used for: sending push notifications to iOS devices
# - Change when: setting up APNS or deploying
# - Obtain from: Apple Developer > Certificates, Identifiers & Profiles
# - APNS_KEY_ID: 10-character identifier from Apple
# - APNS_TEAM_ID: Your Apple Developer Team ID
# - APNS_AUTH_KEY: .p8 file with private key (keep secure)
# - Dev note: Leave commented to disable push notifications
# APNS_KEY_ID=your-apns-key-id
# APNS_TEAM_ID=your-apple-team-id
# APNS_AUTH_KEY=/path/to/AuthKey.p8

# =============================================================================
# BILLING CONFIGURATION (Stripe or Manual)
# =============================================================================
# BILLING_PROVIDER: Which billing system to use
# - Options: "manual" (dev/test - local state only), "stripe" (production)
# - Change when: deploying to production (switch to "stripe")
# - Dev: use "manual" to test billing without Stripe account
# - Prod: use "stripe" for real payment processing
BILLING_PROVIDER=manual

# STRIPE_SECRET_KEY: Stripe API secret key for server-side operations
# - Used for: creating customers, subscriptions, handling payments
# - Change when: enabling Stripe in production
# - Obtain from: Stripe Dashboard > Developers > API Keys > Secret Key
# - Format: sk_live_... (production) or sk_test_... (testing)
# - NEVER commit the actual key - use GitHub Secrets or AWS Secrets Manager
# - Only used if BILLING_PROVIDER=stripe
STRIPE_SECRET_KEY=

# STRIPE_WEBHOOK_SECRET: Secret for verifying Stripe webhook signatures
# - Used for: validating that webhooks come from Stripe (security)
# - Change when: regenerating webhook endpoints in Stripe
# - Obtain from: Stripe Dashboard > Developers > Webhooks > Signing Secret
# - Format: whsec_... (production) or whsec_... (testing)
# - NEVER commit the actual key - use GitHub Secrets or AWS Secrets Manager
# - Only used if BILLING_PROVIDER=stripe
STRIPE_WEBHOOK_SECRET=

# STRIPE_PRICE_FREE, STRIPE_PRICE_STANDARD, STRIPE_PRICE_PRO: Stripe price IDs
# - Used for: identifying which plan the user is subscribing to
# - Format: price_... (e.g. price_1A2B3C4D5E6F7G8H)
# - Change when: creating new prices in Stripe Dashboard or migrating environments
# - Obtain from: Stripe Dashboard > Products > Select Product > Prices
# - These must be recurring (monthly) prices in your Stripe product
# - Free plan: $0 price (still requires payment method)
# - Standard plan: $20.00/month (100 minutes included)
# - Pro plan: $50.00/month (400 minutes included)
# - Only used if BILLING_PROVIDER=stripe
STRIPE_PRICE_FREE=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PRO=

# BILLING_PLANS_JSON: JSON array defining available subscription plans
# - Used for: dynamic plan configuration without code changes
# - Change when: adding/modifying plans, adjusting prices or minute limits
# - Format: JSON array of plan objects with code, name, price_usd, included_minutes, etc.
# - If empty or not set: built-in defaults (Free $0/10min, Standard $20/100min, Pro $50/400min)
# - Prod note: set this to customize plans without redeploying code
BILLING_PLANS_JSON=[{"code":"free","name":"Free","price_usd":"0.00","included_minutes":10,"requires_credit_card":true,"limited":true,"sort_order":0,"description":"Try MattBot with basic call handling","icon":"gift-outline"},{"code":"standard","name":"Standard","price_usd":"20.00","included_minutes":100,"sort_order":1,"description":"For everyday personal use with generous minutes","icon":"star-outline"},{"code":"pro","name":"Pro","price_usd":"50.00","included_minutes":400,"sort_order":2,"description":"High-volume coverage for busy professionals","icon":"rocket-launch-outline"}]

# BILLING_UPGRADE_RULES_JSON: JSON array defining automatic plan upgrade rules
# - Used for: auto-upgrading users when they exceed plan limits
# - Change when: adjusting auto-upgrade behavior
# - Format: JSON array of objects with from_plan, to_plan, trigger
# - Current rule: free -> standard when minutes exceeded
# - If empty or not set: uses built-in default (free overage upgrades to standard)
BILLING_UPGRADE_RULES_JSON=[{"from_plan":"free","to_plan":"standard","trigger":"minutes_exceeded"}]

# STRIPE_PRICE_IDS_JSON: JSON mapping plan codes to Stripe price IDs
# - Used for: mapping plan codes to Stripe price objects for subscription creation
# - Change when: creating new Stripe prices or migrating Stripe environments
# - Format: JSON object {"plan_code": "price_xxx", ...}
# - Overrides individual STRIPE_PRICE_FREE/STANDARD/PRO vars if set
# - Obtain from: Stripe Dashboard > Products > Prices
# - Only used if BILLING_PROVIDER=stripe
STRIPE_PRICE_IDS_JSON={"free":"price_xxx","standard":"price_yyy","pro":"price_zzz"}

# BILLING_PERIOD_DAYS: Length of one billing period in days (manual provider only)
# - Used for: calculating subscription current_period_end when not using Stripe
# - Default: 30
# - Change when: adjusting billing cycle length for manual/dev testing
BILLING_PERIOD_DAYS=30

# BILLING_CONFIG_CACHE_TTL: Seconds to cache billing plan configuration in memory
# - Used for: reducing database queries for plan lookups
# - Default: 60
# - Change when: adjusting how quickly config changes propagate
BILLING_CONFIG_CACHE_TTL=60

# =============================================================================
# TELEPHONY CONFIGURATION (Twilio for Phone Numbers)
# =============================================================================
# TWILIO_ACCOUNT_SID: Twilio Account SID for API access
# - Used for: provisioning phone numbers, managing calls and webhooks
# - Change when: using a different Twilio account
# - Obtain from: Twilio Console > Account > Account SID
# - Format: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# - NEVER commit the actual SID - use GitHub Secrets or AWS Secrets Manager
TWILIO_ACCOUNT_SID=

# TWILIO_AUTH_TOKEN: Twilio Auth Token for API authentication
# - Used for: authenticating API requests to Twilio
# - Change when: regenerating auth token in Twilio Console
# - Obtain from: Twilio Console > Account > Auth Token
# - Format: alphanumeric string (32+ characters)
# - NEVER commit the actual token - use GitHub Secrets or AWS Secrets Manager
TWILIO_AUTH_TOKEN=

# TWILIO_NUMBER_PROVISIONING_ENABLED: Whether to enable Twilio phone number provisioning
# - Options: "true" (enable provisioning), "false" (disable, use mock numbers in dev)
# - Change when: enabling real Twilio provisioning in production
# - Dev: set to "false" to avoid charges and test without Twilio account
# - Prod: set to "true" to provision real phone numbers
TWILIO_NUMBER_PROVISIONING_ENABLED=false

# TWILIO_WEBHOOK_BASE_URL: Base URL for Twilio webhooks to reach your backend
# - Used for: Twilio to call your backend when calls arrive or events occur
# - Change when: deploying to production
# - Must be: publicly accessible HTTPS URL
# - Dev examples: http://localhost:8000 (not working from Twilio), ngrok tunnel
# - Prod example: https://api.mattbot.app
# - Used in: inbound call routing, verification calls, call status updates
TWILIO_WEBHOOK_BASE_URL=

# =============================================================================
# HANDOFF / LIVE TRANSFER
# =============================================================================
# HANDOFF_CALLER_ID: The caller-ID (E.164) used when Twilio dials the user's
# personal phone during a live handoff transfer.
# - Used for: placing the outbound leg of a handoff call via Twilio <Dial>
# - Must be: a Twilio-verified or purchased number on your account
# - Change when: deploying to production or switching Twilio accounts
# - Dev note: Leave empty to disable real transfers (stub TwiML still generated)
HANDOFF_CALLER_ID=

# HANDOFF_OFFER_DEFAULT_TIMEOUT: Seconds before an unanswered handoff offer expires
# - Used for: controlling how long the mobile app shows the "Accept call" banner
# - Default: 20
# - Change when: adjusting handoff UX timing
HANDOFF_OFFER_DEFAULT_TIMEOUT=20

# HANDOFF_TRANSFER_TIMEOUT_CAP: Hard cap (seconds) on the Twilio <Dial> timeout
# - Used for: limiting how long the transfer rings before giving up
# - Default: 30
HANDOFF_TRANSFER_TIMEOUT_CAP=30

# HANDOFF_SUPPRESSION_TTL: Seconds to suppress repeat handoff offers to the same destination
# - Used for: preventing transfer loops when handoff fails
# - Default: 90
HANDOFF_SUPPRESSION_TTL=90

# =============================================================================
# GOOGLE CALENDAR INTEGRATION (OAuth2 for booking appointments)
# =============================================================================
# GOOGLE_CALENDAR_CLIENT_ID: OAuth2 client ID for Google Calendar API
# - Used for: authenticating users to access their Google Calendar
# - Obtain from: Google Cloud Console > APIs & Services > Credentials (Web application type)
# - Must have Calendar API and Gmail API enabled in the project
GOOGLE_CALENDAR_CLIENT_ID=

# GOOGLE_CALENDAR_CLIENT_SECRET: OAuth2 client secret for Google Calendar API
# - Used for: exchanging auth codes for access/refresh tokens
# - Obtain from: same credential page as GOOGLE_CALENDAR_CLIENT_ID
# - NEVER commit the actual secret
GOOGLE_CALENDAR_CLIENT_SECRET=

# GOOGLE_CALENDAR_REDIRECT_URI: OAuth2 callback URL for Google Calendar
# - Must match: the redirect URI configured in Google Cloud Console
# - Prod example: https://mattbot.duckdns.org/api/v1/calendar/callback
GOOGLE_CALENDAR_REDIRECT_URI=

# GOOGLE_CALENDAR_SCOPES: Space-separated OAuth2 scopes for Google Calendar
# - Default includes calendar.events and gmail.readonly
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.events https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/calendar

# =============================================================================
# AI VOICE AGENT (ElevenLabs Conversational AI)
# =============================================================================
# ELEVENLABS_API_KEY: API key for ElevenLabs voice/conversation services
# - Used for: creating AI conversation sessions and fetching transcripts
# - Obtain from: ElevenLabs dashboard > Profile > API Keys
ELEVENLABS_API_KEY=

# ELEVENLABS_AGENT_ID: Agent ID for the screening conversation agent
# - Obtain from: ElevenLabs > Conversational AI > Agents
ELEVENLABS_AGENT_ID=

# ELEVENLABS_WEBHOOK_SECRET: HMAC secret for verifying ElevenLabs webhooks
ELEVENLABS_WEBHOOK_SECRET=

# ELEVENLABS_DEFAULT_VOICE_ID: Platform default ElevenLabs voice ID (fallback when user has no selection)
ELEVENLABS_DEFAULT_VOICE_ID=

# ELEVENLABS_API_BASE_URL: Base URL for the ElevenLabs Conversational AI REST API
# - Used for: fetching transcripts after calls
# - Default: https://api.elevenlabs.io/v1/convai/conversations
# - Change when: using a self-hosted proxy or different API region
ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io/v1/convai/conversations

# ELEVENLABS_TRANSCRIPT_TIMEOUT: HTTP timeout (seconds) when fetching transcripts
# - Default: 30.0
ELEVENLABS_TRANSCRIPT_TIMEOUT=30.0

# ELEVENLABS_TRANSCRIPT_MAX_RETRIES: Max polling retries before giving up on transcript fetch
# - Default: 10
ELEVENLABS_TRANSCRIPT_MAX_RETRIES=10

# =============================================================================
# AGENT / PROMPT CONFIGURATION
# =============================================================================
# AGENT_DEFAULT_SYSTEM_PROMPT_KEY: Key for the default system prompt pack (never exposed to client)
AGENT_DEFAULT_SYSTEM_PROMPT_KEY=default_v1

# =============================================================================
# NODE REALTIME BRIDGE (Twilio Media Streams <-> ElevenLabs)
# =============================================================================
# NODE_BRIDGE_WS_URL: Public WSS URL that Twilio <Stream> connects to
# - Local: use the ngrok URL (FastAPI proxies WS to the local Node bridge)
#   e.g. wss://<your-ngrok>.ngrok-free.dev/twilio/media
# - Prod: wss://realtime.mattbot.app/twilio/media (proper domain)
NODE_BRIDGE_WS_URL=wss://your-ngrok-url.ngrok-free.dev/twilio/media
# NODE_BRIDGE_INTERNAL_URL: HTTP base URL for the Node bridge (health, etc.)
NODE_BRIDGE_INTERNAL_URL=http://localhost:3001
# ENABLE_REALTIME_BRIDGE: Route calls through Node bridge for live transcripts.
# - true: Twilio streams audio via Node bridge -> ElevenLabs (enables live transcript)
# - false: uses ElevenLabs register-call API directly (no live transcript)
ENABLE_REALTIME_BRIDGE=true
# INTERNAL_EVENT_SECRET: Shared HMAC key for Node bridge -> FastAPI events
# - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_EVENT_SECRET=
# INTERNAL_NODE_API_KEY: API key for securing internal endpoints (Node bridge -> FastAPI)
# - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_NODE_API_KEY=

# =============================================================================
# OBSERVABILITY CONFIGURATION (Error Tracking and Monitoring)
# =============================================================================
# SENTRY_DSN: Sentry DSN for error tracking and performance monitoring
# - Used for: capturing exceptions, performance metrics, and error reporting
# - Change when: deploying to production or using different Sentry project
# - Obtain from: Sentry Dashboard > Projects > Project Settings > Client Keys (DSN)
# - Format: https://xxxxxxxxxx@xxxxx.ingest.sentry.io/xxxxxxxxx
# - Dev note: Leave empty to disable error tracking
SENTRY_DSN=

# SENTRY_TRACES_SAMPLE_RATE: Fraction of requests to capture as performance traces
# - Used for: controlling Sentry performance monitoring volume and cost
# - Range: 0.0 (disabled) to 1.0 (every request)
# - Default: 0.1 (10% of requests)
# - Change when: adjusting performance monitoring cost/granularity
SENTRY_TRACES_SAMPLE_RATE=0.1

# ENVIRONMENT: Deployment environment indicator
# - Options: "development", "staging", "production", "test", "local"
# - Used for: environment-specific logging, features, and behaviors
# - Change when: deploying to different environments
# - Dev: set to "development" for verbose logging and debug features
# - Prod: set to "production" for optimized performance and minimal logging
ENVIRONMENT=development

# =============================================================================
# APP BASE URL CONFIGURATION
# =============================================================================
# API_BASE_URL: The public-facing base URL of this backend API
# - Used for: generating absolute URLs in emails, webhooks, and deep links
# - Change when: deploying to a new domain or environment
# - Dev: http://localhost:8000
# - Prod: https://api.mattbot.app
API_BASE_URL=http://localhost:8000

# =============================================================================
# RATE LIMITING (Tiered — tune per tier, not per endpoint)
# =============================================================================
# Rate limits are grouped into tiers. Each API endpoint picks a tier.
# Override a tier to adjust all endpoints in that group at once.
# For per-endpoint overrides, use RATE_LIMIT_OVERRIDES_JSON below.

# --- Auth IP tier (IP-based auth endpoints: register, login, OAuth, MFA, OTP verify) ---
# RATE_LIMIT_AUTH_IP_MAX: Max requests from one IP in the auth IP window
# - Default: 20
RATE_LIMIT_AUTH_IP_MAX=20
# RATE_LIMIT_AUTH_IP_WINDOW: Window in seconds for auth IP rate limiting
# - Default: 600 (10 minutes)
RATE_LIMIT_AUTH_IP_WINDOW=600

# --- Auth account tier (per-account: login attempts, MFA, step-up) ---
# RATE_LIMIT_AUTH_ACCOUNT_MAX: Max requests per account in the auth account window
# - Default: 5
RATE_LIMIT_AUTH_ACCOUNT_MAX=5
# RATE_LIMIT_AUTH_ACCOUNT_WINDOW: Window in seconds for per-account auth limiting
# - Default: 600 (10 minutes)
RATE_LIMIT_AUTH_ACCOUNT_WINDOW=600

# --- Auth sensitive tier (OTP request, password reset request — most restrictive) ---
# RATE_LIMIT_AUTH_SENSITIVE_MAX: Max requests for sensitive auth operations
# - Default: 3
RATE_LIMIT_AUTH_SENSITIVE_MAX=3
# RATE_LIMIT_AUTH_SENSITIVE_WINDOW: Window in seconds for sensitive auth limiting
# - Default: 3600 (1 hour)
RATE_LIMIT_AUTH_SENSITIVE_WINDOW=3600

# --- API standard tier (read-heavy user endpoints: list calls, list VIP, etc.) ---
# RATE_LIMIT_API_STANDARD_MAX: Max requests per user in the standard API window
# - Default: 30
RATE_LIMIT_API_STANDARD_MAX=30
# RATE_LIMIT_API_STANDARD_WINDOW: Window in seconds for standard API limiting
# - Default: 60
RATE_LIMIT_API_STANDARD_WINDOW=60

# --- API write tier (write/mutate user endpoints: PATCH, POST, DELETE) ---
# RATE_LIMIT_API_WRITE_MAX: Max requests per user in the write API window
# - Default: 20
RATE_LIMIT_API_WRITE_MAX=20
# RATE_LIMIT_API_WRITE_WINDOW: Window in seconds for write API limiting
# - Default: 60
RATE_LIMIT_API_WRITE_WINDOW=60

# --- Webhook tier (Twilio, ElevenLabs, Stripe inbound webhooks) ---
# RATE_LIMIT_WEBHOOK_MAX: Max webhook calls per source in the webhook window
# - Default: 60
RATE_LIMIT_WEBHOOK_MAX=60
# RATE_LIMIT_WEBHOOK_WINDOW: Window in seconds for webhook rate limiting
# - Default: 60
RATE_LIMIT_WEBHOOK_WINDOW=60

# --- Internal tier (Node bridge → backend internal endpoints) ---
# RATE_LIMIT_INTERNAL_MAX: Max internal API calls in the internal window
# - Default: 100
RATE_LIMIT_INTERNAL_MAX=100
# RATE_LIMIT_INTERNAL_WINDOW: Window in seconds for internal API limiting
# - Default: 60
RATE_LIMIT_INTERNAL_WINDOW=60

# RATE_LIMIT_OVERRIDES_JSON: Per-endpoint overrides as JSON object
# - Used for: fine-tuning individual endpoints beyond tier defaults
# - Format: {"rate_limit_key_prefix": {"max": N, "window": N}, ...}
# - Example: {"regen_summary": {"max": 5, "window": 120}}
# - Default: empty (no overrides)
RATE_LIMIT_OVERRIDES_JSON=

# =============================================================================
# EXTERNAL SERVICE TIMEOUTS
# =============================================================================
# SENDGRID_TIMEOUT: HTTP request timeout in seconds for SendGrid API calls
# - Default: 10.0
SENDGRID_TIMEOUT=10.0

# SENDGRID_MAX_RETRIES: Number of retries on transient SendGrid failures (5xx, 429)
# - Default: 2
SENDGRID_MAX_RETRIES=2

# SENDGRID_RETRY_DELAY: Base delay in seconds between SendGrid retries (exponential backoff)
# - Default: 0.5
SENDGRID_RETRY_DELAY=0.5

# APPLE_JWKS_TIMEOUT: HTTP timeout in seconds for fetching Apple Sign-In JWKS keys
# - Default: 10
APPLE_JWKS_TIMEOUT=10

# EVENT_EMITTER_TIMEOUT: HTTP timeout in seconds for pushing events to Node bridge
# - Default: 10.0
EVENT_EMITTER_TIMEOUT=10.0

# =============================================================================
# TOKEN / SESSION EXPIRY
# =============================================================================
# EMAIL_VERIFY_TOKEN_TTL: Lifetime in seconds for email verification tokens
# - Default: 900 (15 minutes)
EMAIL_VERIFY_TOKEN_TTL=900

# PASSWORD_RESET_TOKEN_TTL: Lifetime in seconds for password reset tokens
# - Default: 900 (15 minutes)
PASSWORD_RESET_TOKEN_TTL=900

# EMAIL_OTP_TTL: Lifetime in seconds for email one-time passcodes
# - Default: 600 (10 minutes)
EMAIL_OTP_TTL=600

# MFA_CHALLENGE_EXPIRY_MINUTES: Lifetime in minutes for MFA challenge/enrollment tokens
# - Default: 10
MFA_CHALLENGE_EXPIRY_MINUTES=10

# STEP_UP_TOKEN_EXPIRY_MINUTES: Lifetime in minutes for step-up authentication tokens
# - Default: 5
STEP_UP_TOKEN_EXPIRY_MINUTES=5

# STREAM_SESSION_TOKEN_TTL: Lifetime in seconds for Twilio stream session tokens
# - Default: 300 (5 minutes)
STREAM_SESSION_TOKEN_TTL=300

# =============================================================================
# FEATURE THRESHOLDS AND OPERATIONAL DEFAULTS
# =============================================================================
# DEFAULT_CALL_RETENTION_DAYS: Days to keep call records before soft-deletion
# - Used for: retention worker scheduling and default retention_expires_at
# - Default: 90
DEFAULT_CALL_RETENTION_DAYS=90

# DEFAULT_MAX_CALL_SECONDS: Maximum call duration in seconds for regular callers
# - Used for: TwiML generation and call length enforcement
# - Default: 180 (3 minutes)
DEFAULT_MAX_CALL_SECONDS=180

# VIP_MAX_CALL_SECONDS: Maximum call duration in seconds for VIP callers
# - Used for: TwiML generation — VIP callers get a longer allowed duration
# - Default: 300 (5 minutes)
VIP_MAX_CALL_SECONDS=300

# FWD_DETECT_THRESHOLD: Number of forwarding hits before triggering a misconfiguration warning
# - Default: 3
FWD_DETECT_THRESHOLD=3

# FWD_DETECT_WINDOW_SECONDS: Time window in seconds for forwarding detection counter
# - Default: 3600 (1 hour)
FWD_DETECT_WINDOW_SECONDS=3600

# NUMBER_PENDING_TTL_MINUTES: Minutes before a pending phone number provisioning expires
# - Default: 15
NUMBER_PENDING_TTL_MINUTES=15

# DEFAULT_ASSISTANT_NAME: Default name for the AI assistant shown to callers
# - Default: "Alex"
# - Change when: branding or persona customization
DEFAULT_ASSISTANT_NAME=Alex

# =============================================================================
# WORKER INTERVALS (Background Polling Loops)
# =============================================================================
# All values are in seconds. Lower values increase responsiveness but add load.

# WORKER_POST_CALL_INTERVAL: Sleep between post-call artifact processing cycles
# - Default: 15
WORKER_POST_CALL_INTERVAL=15

# WORKER_REMINDER_INTERVAL: Sleep between reminder due-date polling cycles
# - Default: 60
WORKER_REMINDER_INTERVAL=60

# WORKER_SMS_INTERVAL: Sleep between SMS send queue processing cycles
# - Default: 30
WORKER_SMS_INTERVAL=30

# WORKER_HANDOFF_EXPIRY_INTERVAL: Sleep between handoff offer expiry sweeps
# - Default: 5
WORKER_HANDOFF_EXPIRY_INTERVAL=5

# WORKER_NUMBER_LIFECYCLE_INTERVAL: Sleep between number lifecycle tasks (cleanup, repair)
# - Default: 300 (5 minutes)
WORKER_NUMBER_LIFECYCLE_INTERVAL=300

# WORKER_RETENTION_INTERVAL: Sleep between data retention enforcement cycles
# - Default: 1800 (30 minutes)
WORKER_RETENTION_INTERVAL=1800

# WORKER_HARD_DELETION_INTERVAL: Sleep between hard deletion of soft-deleted records
# - Default: 3600 (1 hour)
WORKER_HARD_DELETION_INTERVAL=3600

# =============================================================================
# PAGINATION DEFAULTS
# =============================================================================
# DEFAULT_PAGE_SIZE: Default number of items returned per page in list endpoints
# - Default: 20
DEFAULT_PAGE_SIZE=20

# MAX_PAGE_SIZE: Maximum allowed page size a client can request
# - Default: 50
MAX_PAGE_SIZE=50
