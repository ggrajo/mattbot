# =============================================================================
# REALTIME BRIDGE CONFIGURATION (Twilio Media Streams <-> ElevenLabs)
# =============================================================================

# PORT: The port the bridge HTTP/WS server listens on
# - Default: 3001
PORT=3001

# ELEVENLABS_API_KEY: API key for ElevenLabs speech-to-speech WebSocket
# - Obtain from: ElevenLabs dashboard > Profile > API Keys
# - Must match: the key in the backend .env
ELEVENLABS_API_KEY=

# ELEVENLABS_AGENT_ID: Agent ID for the screening conversation agent
# - Obtain from: ElevenLabs > Conversational AI > Agents
ELEVENLABS_AGENT_ID=

# INTERNAL_EVENT_SECRET: Shared HMAC key for signing events sent to the backend
# - Must match: INTERNAL_EVENT_SECRET in the backend .env
# - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_EVENT_SECRET=

# INTERNAL_NODE_API_KEY: API key for internal endpoint auth (bridge -> backend)
# - Must match: INTERNAL_NODE_API_KEY in the backend .env
# - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_NODE_API_KEY=

# JWT_SIGNING_KEY: Secret key for verifying mobile client JWT tokens on WebSocket auth
# - Must match: JWT_SIGNING_KEY in the backend .env
# - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SIGNING_KEY=

# LOG_LEVEL: Logging verbosity
# - Options: "debug", "info", "warn", "error"
# - Default: "info"
# - Change when: debugging issues in development or reducing noise in production
LOG_LEVEL=info

# BACKEND_INTERNAL_URL: The FastAPI backend base URL for internal calls
# - Used for: fetching agent config, emitting lifecycle events
# - Dev: http://localhost:8000
# - Prod: internal VPC URL to backend service
BACKEND_INTERNAL_URL=http://localhost:8000

# MAX_CONCURRENT_SESSIONS: Global limit on simultaneous streaming sessions
# - Used for: backpressure control and resource management
# - Default: 10 (dev), increase in prod based on capacity
MAX_CONCURRENT_SESSIONS=10

# MAX_SESSIONS_PER_USER: Per-user limit on concurrent streaming sessions
# - Used for: preventing abuse from a single user
# - Default: 2
MAX_SESSIONS_PER_USER=2

# =============================================================================
# ELEVENLABS CONFIGURATION
# =============================================================================
# ELEVENLABS_WS_URL: WebSocket URL for the ElevenLabs Conversational AI streaming API
# - Default: wss://api.elevenlabs.io/v1/convai/conversation
# - Change when: using a proxy or different API region
ELEVENLABS_WS_URL=wss://api.elevenlabs.io/v1/convai/conversation

# ELEVENLABS_BUFFER_LIMIT_BYTES: Max buffered bytes before dropping audio frames (backpressure)
# - Default: 512000 (512 KB)
# - Change when: adjusting audio quality vs memory trade-off
ELEVENLABS_BUFFER_LIMIT_BYTES=512000

# =============================================================================
# TIMEOUT CONFIGURATION
# =============================================================================
# WS_AUTH_TIMEOUT_MS: Milliseconds to wait for WebSocket authentication before closing
# - Default: 5000 (5 seconds)
WS_AUTH_TIMEOUT_MS=5000

# AGENT_RUNTIME_FETCH_TIMEOUT_MS: Milliseconds timeout for fetching agent config from backend
# - Default: 5000 (5 seconds)
AGENT_RUNTIME_FETCH_TIMEOUT_MS=5000

# EVENT_EMISSION_TIMEOUT_MS: Milliseconds timeout for emitting lifecycle events to backend
# - Default: 10000 (10 seconds)
EVENT_EMISSION_TIMEOUT_MS=10000

# HANDOFF_DECISION_TIMEOUT_MS: Milliseconds timeout for forwarding handoff decisions to backend
# - Default: 10000 (10 seconds)
HANDOFF_DECISION_TIMEOUT_MS=10000
