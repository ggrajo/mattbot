# =============================================================================
# REALTIME BRIDGE — DEV SERVER CONFIGURATION
# =============================================================================
# Environment template for the EC2 dev server.
# This file configures the Node.js realtime bridge that connects
# Twilio Media Streams to ElevenLabs Conversational AI.
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# PORT: HTTP/WebSocket port the realtime bridge listens on
# - Used for: accepting Twilio Media Stream WebSocket connections
# - Change when: port 3001 conflicts with another service
# - Default: 3001
PORT=3001

# =============================================================================
# ELEVENLABS CONFIGURATION (Voice AI Provider)
# =============================================================================
# ELEVENLABS_API_KEY: API key for ElevenLabs voice/conversation services
# - Used for: authenticating WebSocket connections to ElevenLabs Conversational AI
# - Obtain from: ElevenLabs dashboard > Profile > API Keys
# - Format: sk_... (starts with "sk_")
# - NEVER commit the actual key in production — use a secret manager
ELEVENLABS_API_KEY=sk_4504d9adb1fd56c66c381afb659bb0715a8362ed000721a5

# ELEVENLABS_AGENT_ID: Agent ID for the screening conversation agent
# - Used for: identifying which ElevenLabs agent handles the call
# - Obtain from: ElevenLabs > Conversational AI > Agents
# - Dev note: Leave empty — auto-provisioned by the backend per-call
ELEVENLABS_AGENT_ID=

# =============================================================================
# SECURITY KEYS (Shared with Backend)
# =============================================================================
# INTERNAL_EVENT_SECRET: Shared HMAC key for Node bridge -> FastAPI event signatures
# - Used for: signing event payloads sent from the bridge to the backend
# - Must match: the same value set in the backend .env
# - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# - NEVER commit the actual key in production — use a secret manager
INTERNAL_EVENT_SECRET=***JWT_KEY_REDACTED***

# INTERNAL_NODE_API_KEY: API key for securing internal endpoints (Node bridge -> FastAPI)
# - Used for: authenticating internal HTTP calls from the bridge to backend
# - Must match: the same value set in the backend .env
# - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# - NEVER commit the actual key in production — use a secret manager
INTERNAL_NODE_API_KEY=dev_internal_node_api_key_change_in_prod

# JWT_SIGNING_KEY: Secret key for verifying JWT tokens (minimum 32 bytes)
# - Used for: validating access tokens on WebSocket upgrade requests
# - Must match: the same JWT_SIGNING_KEY used by the backend
# - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# - NEVER commit the actual key in production — use a secret manager
JWT_SIGNING_KEY=***JWT_KEY_REDACTED***

# =============================================================================
# LOGGING
# =============================================================================
# LOG_LEVEL: Minimum log level for the bridge process
# - Options: "debug", "info", "warn", "error"
# - Dev: "debug" or "info" for verbose output
# - Prod: "warn" or "error" to reduce noise
LOG_LEVEL=info

# =============================================================================
# BACKEND CONNECTIVITY
# =============================================================================
# BACKEND_INTERNAL_URL: HTTP base URL for reaching the FastAPI backend
# - Used for: fetching agent runtime config, emitting call events
# - Dev (Docker Compose): http://backend:8000 (Docker service name)
# - Dev (local): http://localhost:8000
# - Prod: http://backend:8000 or internal load-balancer URL
BACKEND_INTERNAL_URL=http://backend:8000

# =============================================================================
# SESSION LIMITS
# =============================================================================
# MAX_CONCURRENT_SESSIONS: Maximum simultaneous WebSocket bridge sessions
# - Used for: protecting the bridge from overload
# - Dev: 10 (low for testing)
# - Prod: scale based on instance size (e.g. 500)
MAX_CONCURRENT_SESSIONS=10

# MAX_SESSIONS_PER_USER: Maximum simultaneous sessions for a single user
# - Used for: preventing one user from consuming all capacity
# - Dev: 2
# - Prod: 5–10 depending on plan
MAX_SESSIONS_PER_USER=2

# =============================================================================
# ELEVENLABS WEBSOCKET SETTINGS
# =============================================================================
# ELEVENLABS_WS_URL: WebSocket URL for ElevenLabs Conversational AI
# - Used for: establishing the upstream AI voice connection
# - Default: wss://api.elevenlabs.io/v1/convai/conversation
# - Change when: using a proxy or different API region
ELEVENLABS_WS_URL=wss://api.elevenlabs.io/v1/convai/conversation

# ELEVENLABS_BUFFER_LIMIT_BYTES: Max audio buffer size (bytes) before force-flush
# - Used for: preventing unbounded memory growth on slow connections
# - Default: 512000 (500 KB)
# - Change when: tuning memory usage vs. audio latency
ELEVENLABS_BUFFER_LIMIT_BYTES=512000

# =============================================================================
# TIMEOUT CONFIGURATION
# =============================================================================
# WS_AUTH_TIMEOUT_MS: Milliseconds to wait for auth on new WebSocket connections
# - Used for: rejecting unauthenticated connections that never send credentials
# - Default: 5000 (5 seconds)
WS_AUTH_TIMEOUT_MS=5000

# AGENT_RUNTIME_FETCH_TIMEOUT_MS: Milliseconds to wait for agent runtime config from backend
# - Used for: HTTP GET to backend for per-call agent configuration
# - Default: 5000 (5 seconds)
AGENT_RUNTIME_FETCH_TIMEOUT_MS=5000

# EVENT_EMISSION_TIMEOUT_MS: Milliseconds to wait when posting events to backend
# - Used for: HTTP POST of transcript/call events to FastAPI
# - Default: 10000 (10 seconds)
EVENT_EMISSION_TIMEOUT_MS=10000

# HANDOFF_DECISION_TIMEOUT_MS: Milliseconds to wait for a handoff decision from backend
# - Used for: HTTP call to backend to determine live-transfer routing
# - Default: 10000 (10 seconds)
HANDOFF_DECISION_TIMEOUT_MS=10000
