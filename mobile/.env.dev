# =============================================================================
# API CONFIGURATION
# =============================================================================
# API_BASE_URL: Base URL for all backend API calls
# - Used for: making HTTP requests to the backend API endpoints
# - Change when: deploying to production or using a different backend
# - Dev examples:
#   - Local: http://localhost:8000/api/v1
#   - Android emulator: http://10.0.2.2:8000/api/v1
#   - iOS simulator: http://localhost:8000/api/v1
# - Prod example: https://api.mattbot.app/api/v1
API_BASE_URL=http://3.238.82.209/api/v1

# =============================================================================
# OAUTH PROVIDERS (Google Sign-In)
# =============================================================================
# GOOGLE_WEB_CLIENT_ID: OAuth client ID for Google Sign-In on web
# - Used for: authenticating users via Google OAuth in the mobile app
# - Change when: deploying to production or using a different Google project
# - Obtain from: Google Cloud Console > APIs & Services > Credentials
# - Note: This is the WEB client ID (different from iOS/Android specific IDs)
# - Format: numeric-string.apps.googleusercontent.com
# - Dev note: Leave empty to disable Google Sign-In or use dummy value for testing
# - Apple Sign-In is configured via Xcode project settings, not env vars
GOOGLE_WEB_CLIENT_ID=***GOOGLE_CLIENT_ID_REDACTED***

# =============================================================================
# PAYMENT PROCESSING (Stripe)
# =============================================================================
# STRIPE_PUBLISHABLE_KEY: Stripe publishable key for client-side operations
# - Used for: initializing Stripe SDK for card entry and payment collection
# - Change when: deploying to production or switching Stripe accounts
# - Obtain from: Stripe Dashboard > Developers > API Keys > Publishable Key
# - Format: pk_live_... (production) or pk_test_... (testing)
# - IMPORTANT: This key is exposed to users (it's meant to be public)
# - Do NOT confuse with STRIPE_SECRET_KEY (that stays on backend)
# - Dev: use pk_test_... key for testing payments
# - Prod: use pk_live_... key for real payments
STRIPE_PUBLISHABLE_KEY=

# BILLING_MODE: Controls billing behavior
# - Options: "stripe" (real payments via Stripe), "manual" (bypass payments for dev/testing)
# - Dev: use "manual" to skip real Stripe calls during development
# - Prod: use "stripe" for live payment processing
BILLING_MODE=manual

# =============================================================================
# THEME CONFIGURATION
# =============================================================================
# THEME_DEFAULT: Default theme mode when user hasn't set preference
# - Options: "light" (always light mode), "dark" (always dark mode), "system" (follow device settings)
# - Used for: initial theme on app launch before user changes it
# - Change when: preferring a different default appearance
# - "system": automatically follows the device's Light/Dark mode setting
# - User can override this choice in Settings > Appearance at any time
# - Backend syncs user's choice for cross-device consistency
THEME_DEFAULT=system

# =============================================================================
# OBSERVABILITY CONFIGURATION (Error Tracking and Monitoring)
# =============================================================================
# SENTRY_DSN: Sentry DSN for error tracking and performance monitoring
# - Used for: capturing crashes, exceptions, and performance metrics
# - Change when: deploying to production or using different Sentry project
# - Obtain from: Sentry Dashboard > Projects > Project Settings > Client Keys (DSN)
# - Format: https://xxxxxxxxxx@xxxxx.ingest.sentry.io/xxxxxxxxx
# - Dev note: Leave empty to disable error tracking
SENTRY_DSN=https://fa096def3b0286c6149e36e7782ec8a8@o4510919789314048.ingest.us.sentry.io/4510919806222336

# ENVIRONMENT: Deployment environment indicator
# - Options: "development", "staging", "production", "test", "local"
# - Used for: environment-specific logging, features, error reporting
# - Change when: deploying to different environments
# - Dev: set to "development" for verbose logging and debug features
# - Prod: set to "production" for optimized performance and minimal logging
ENVIRONMENT=development

# =============================================================================
# REALTIME WEBSOCKET
# =============================================================================
# REALTIME_WS_URL: WebSocket URL for realtime events from the Node.js bridge
# - Used for: receiving live call events, handoff offers, transcript/summary ready
# - Change when: deploying to production or using a different bridge instance
# - Dev examples:
#   - Local: ws://localhost:3001/ws/events
#   - Android emulator: ws://10.0.2.2:3001/ws/events
# - Prod example: wss://realtime.mattbot.app/ws/events
REALTIME_WS_URL=ws://3.238.82.209/ws/events

# =============================================================================
# NETWORK AND TIMEOUT CONFIGURATION
# =============================================================================
# API_TIMEOUT_MS: HTTP request timeout in milliseconds for all API calls
# - Default: 15000 (15 seconds)
# - Change when: adjusting for slow networks or backend response times
API_TIMEOUT_MS=15000

# WS_RECONNECT_INITIAL_MS: Initial delay before first WebSocket reconnection attempt
# - Default: 1000 (1 second)
# - Change when: adjusting reconnection aggressiveness
WS_RECONNECT_INITIAL_MS=1000

# WS_RECONNECT_MAX_MS: Maximum delay between WebSocket reconnection attempts
# - Default: 30000 (30 seconds)
# - Change when: adjusting reconnection back-off ceiling
WS_RECONNECT_MAX_MS=30000

# =============================================================================
# DEEP LINKING
# =============================================================================
# DEEP_LINK_SCHEME: URL scheme for deep links (e.g. "mattbot" → mattbot://...)
# - Default: mattbot
# - Change when: using a custom URL scheme for your app build
DEEP_LINK_SCHEME=mattbot

# =============================================================================
# HANDOFF CONFIGURATION
# =============================================================================
# HANDOFF_OFFER_TIMEOUT_MS: Milliseconds before a handoff offer auto-expires in the UI
# - Default: 20000 (20 seconds)
# - Should match: HANDOFF_OFFER_DEFAULT_TIMEOUT in the backend .env (converted to ms)
HANDOFF_OFFER_TIMEOUT_MS=20000
