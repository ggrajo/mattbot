# =============================================================================
# API CONFIGURATION
# =============================================================================
API_BASE_URL=https://api.mattbot.app/api/v1

# =============================================================================
# OAUTH PROVIDERS (Google Sign-In)
# =============================================================================
GOOGLE_WEB_CLIENT_ID=your-prod-google-web-client-id.apps.googleusercontent.com

# =============================================================================
# PAYMENT PROCESSING (Stripe)
# =============================================================================
STRIPE_PUBLISHABLE_KEY=pk_live_xxxx

# =============================================================================
# THEME CONFIGURATION
# =============================================================================
THEME_DEFAULT=system

# =============================================================================
# OBSERVABILITY CONFIGURATION (Error Tracking and Monitoring)
# =============================================================================
SENTRY_DSN=your-prod-sentry-dsn

# ENVIRONMENT: Deployment environment indicator
ENVIRONMENT=production

# =============================================================================
# REALTIME WEBSOCKET
# =============================================================================
REALTIME_WS_URL=wss://realtime.mattbot.app/ws/events

# =============================================================================
# NETWORK AND TIMEOUT CONFIGURATION
# =============================================================================
API_TIMEOUT_MS=15000
WS_RECONNECT_INITIAL_MS=1000
WS_RECONNECT_MAX_MS=30000

# =============================================================================
# DEEP LINKING
# =============================================================================
DEEP_LINK_SCHEME=mattbot

# =============================================================================
# HANDOFF CONFIGURATION
# =============================================================================
HANDOFF_OFFER_TIMEOUT_MS=20000
